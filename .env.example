# Copy this file to ".env" and fill in your values, then restart the server.

# ---- Database (required) ----
# A Postgres connection string. Easiest free option: https://neon.tech
# Create a project, copy the connection string (it looks like the line below).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ---- Google OAuth (recommended for multi-user email) ----
# Powers "Connect your Google account" so EACH user can send emails as themselves
# (their own name/address) via the Gmail API — no app passwords. Also enables the
# Gmail/contacts read integration. For an internal company tool, set the OAuth
# consent screen to "Internal" so all Workspace users can connect without app review.
# Create at https://console.cloud.google.com → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must EXACTLY match an Authorized redirect URI on your Google OAuth client.
# Local dev: http://localhost:3000/api/google/callback
# Production: https://YOUR-APP.onrender.com/api/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ---- Email sending ----
# Primary path is per-user Gmail: each user clicks "Connect Google account" on the
# Messages page and sends as themselves (needs the Google OAuth block above).
#
# Optional shared SMTP fallback — used only for users who haven't connected Google
# (e.g. automated/system mail). Requires a Google App Password:
#   1) The account must have 2-Step Verification ON.
#   2) Create an App Password: Google Account → Security → App passwords.
#   3) SMTP_USER is the full mailbox; SMTP_PASS is that 16-char app password
#      (spaces are fine, they're stripped automatically).
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=your-16-char-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=LeadFlow <you@yourdomain.com>

# A random secret that protects the dispatch endpoint. The external cron must pass
# it as ?key=... (call GET https://YOUR-APP/api/cron/dispatch?key=YOUR_SECRET every
# few minutes, e.g. via https://cron-job.org or a GitHub Actions scheduled job).
CRON_SECRET=set-a-long-random-string

# Set to "production" when deployed (enables secure cookies). Render sets this automatically.
# NODE_ENV=production
